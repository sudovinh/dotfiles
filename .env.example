# Dotfiles Configuration
# Copy this file to .env and customize for your setup
#
# Required variables must be set — setup will fail with a clear error if missing.
# Optional variables can be left commented out to skip that feature.

# ── Required ────────────────────────────────────────────────────────────────

# Your GitHub username (used for chezmoi init)
GIT_USER=your-github-username

# Profile selects which Brewfile, Devbox config, and Claude settings to use
# Options: main | work
PROFILE=main

# ── Optional ─────────────────────────────────────────────────────────────────
# Leave commented out to skip cloning these repos

# Private repository for sensitive configs (zsh aliases, secrets, etc.)
# DEV_SETUP_REPO=git@github.com:your-username/dev_setup.git

# Obsidian notes repository
# OBSIDIAN_NOTES_REPO=git@github.com:your-username/second-brain.git

# macOS Defaults Overrides (optional)
# Set to "false" to skip that setting, or customize values
# MACOS_DOCK_AUTOHIDE=true
# MACOS_DOCK_ICON_SIZE=48
# MACOS_FINDER_SHOW_HIDDEN=true
# MACOS_KEYBOARD_REPEAT_RATE=2
# MACOS_KEYBOARD_INITIAL_DELAY=15
# MACOS_SCREENSHOT_LOCATION="${HOME}/Screenshots"
# MACOS_DISABLE_BOOT_SOUND=true
# MACOS_DISABLE_AUTOCORRECT=true
# MACOS_TAP_TO_CLICK=true
# MACOS_THREE_FINGER_DRAG=true
