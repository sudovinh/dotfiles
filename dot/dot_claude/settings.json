{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(diskutil list:*)",
      "Bash(sudo zpool:*)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/plugins/tmux-claude-status/hooks/tmux-claude-status-hook.sh SessionStart"
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/chezmoi-session-sync",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | jq -r '.command // empty' | grep -qE 'rm -rf|rm -r [^-]|rm .* \\*|rm .* \\.\\*|git clean -fd|git reset --hard' && echo 'BLOCKED: Dangerous destructive command detected.' >&2 && exit 2 || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(echo \"$CLAUDE_TOOL_INPUT\" | jq -r '.file_path // empty'); test -n \"$file\" && echo \"$file\" | grep -qE 'CLAUDE\\.md$|CLAUDE\\.local\\.md$|\\.claude/' && flock -w 5 ~/.claude-backup.lock -c \"chezmoi add \\\"$file\\\"\" >/dev/null 2>&1 & true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/plugins/tmux-claude-status/hooks/tmux-claude-status-hook.sh UserPromptSubmit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/plugins/tmux-claude-status/hooks/tmux-claude-status-hook.sh Stop"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "flock -w 5 ~/.claude-backup.lock -c 'chezmoi re-add' >/dev/null 2>&1 & git -C ~/dev_setup add -u >/dev/null 2>&1 && git -C ~/dev_setup diff --cached --quiet || git -C ~/dev_setup commit -m 'auto: session backup' >/dev/null 2>&1 && git -C ~/dev_setup push >/dev/null 2>&1 &"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/plugins/tmux-claude-status/hooks/tmux-claude-status-hook.sh Notification"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/plugins/tmux-claude-status/hooks/tmux-claude-status-hook.sh SessionEnd"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    }
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true
  },
  "mcpServers": {},
  "preferences": {
    "tmuxSplitPanes": true
  },
  "skillFolders": [
    "~/dotfiles/claude/skills",
    "~/dev_setup/claude/skills",
    "~/dev_setup/claude/skills_main"
  ]
}
